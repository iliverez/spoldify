<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Spoldify" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/spotify_green</item>
        <item name="colorPrimaryDark">@color/spotify_green_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSurface">@color/bg_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_card</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:windowSplashScreenBackground">@color/bg_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="materialButtonStyle">@style/Widget.Spoldify.Button</item>
        <item name="editTextStyle">@style/Widget.Spoldify.EditText</item>
        <item name="bottomNavigationStyle">@style/Widget.Spoldify.BottomNavigationView</item>
    </style>

    <style name="Widget.Spoldify.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/spotify_green</item>
        <item name="android:textColor">@color/black</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">40dp</item>
    </style>

    <style name="Widget.Spoldify.EditText" parent="Widget.Material3.TextInputLayout.FilledBox.Dense">
        <item name="boxBackgroundColor">@color/bg_card</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <style name="Widget.Spoldify.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/bg_bottom_nav</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Spoldify.BottomNavigationView.ActiveIndicator</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.Spoldify.BottomNavigationView.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/bg_card</item>
    </style>

    <style name="CompactTextView" parent="android:Widget.TextView">
        <item name="android:textSize">12sp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
    </style>
</resources>
